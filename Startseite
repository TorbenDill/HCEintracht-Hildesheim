<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HC Eintracht Hildesheim – Wolfpack</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --lava:#36393E;--lava-deep:#1C1F23;--lava-mid:#2C2F34;
  --lime:#92BA4A;--lime-bright:#A8D055;--lime-dark:#6E8E35;
  --lime-dim:rgba(146,186,74,0.12);
  --white:#F5F5F2;--gray:#9A9DA3;--gray-light:#C8CCD2;
}
html{scroll-behavior:smooth}
body{background:var(--lava-deep);color:var(--white);font-family:'Arial Narrow',Arial,sans-serif;overflow-x:hidden}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:var(--lava-deep)}::-webkit-scrollbar-thumb{background:var(--lime-dark)}
.topbar{background:var(--lava-deep);border-bottom:1px solid rgba(146,186,74,.1);height:34px;display:flex;align-items:center;justify-content:space-between;padding:0 40px;z-index:300;position:relative}
.topbar a{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--gray);text-decoration:none;transition:color .2s}
.topbar a:hover{color:var(--lime)}
.tb-l,.tb-r{display:flex;gap:20px;align-items:center}
.tb-sep{width:1px;height:12px;background:rgba(255,255,255,.08)}
.soc{display:flex;gap:12px}.soc a{display:flex;align-items:center;opacity:.4;transition:opacity .2s}.soc a:hover{opacity:1}.soc svg{width:13px;height:13px;fill:var(--white)}
nav{background:var(--lava);border-bottom:2.5px solid var(--lime);position:sticky;top:0;z-index:200;padding:0 40px}
.nav-inner{display:flex;align-items:stretch;height:62px}
.nbrand{display:flex;align-items:center;gap:12px;text-decoration:none;margin-right:20px;flex-shrink:0}
.nbadge{width:46px;height:46px;border-radius:50%;border:2px solid var(--lime);display:flex;align-items:center;justify-content:center;background:transparent;overflow:hidden}
.nbadge img{width:40px;height:40px;object-fit:contain}
.nbtext b{display:block;font-size:13px;letter-spacing:.2em;text-transform:uppercase;color:var(--white);font-weight:900;line-height:1.1}
.nbtext span{display:block;font-size:9.5px;letter-spacing:.28em;text-transform:uppercase;color:var(--lime)}
.nlinks{display:flex;align-items:stretch;flex:1}
.ni{position:relative;display:flex;align-items:center}
.ni>a,.ni>button{height:100%;padding:0 13px;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gray-light);text-decoration:none;background:none;border:none;cursor:pointer;white-space:nowrap;display:flex;align-items:center;gap:4px;transition:color .2s;position:relative}
.ni>a::after,.ni>button::after{content:'';position:absolute;bottom:0;left:13px;right:13px;height:2px;background:var(--lime);transform:scaleX(0);transition:transform .2s;transform-origin:left}
.ni:hover>a,.ni:hover>button{color:var(--white)}.ni:hover>a::after,.ni:hover>button::after{transform:scaleX(1)}
.ni.hot>a{color:var(--lime)}
.chev{width:7px;height:7px;border-right:1.5px solid currentColor;border-bottom:1.5px solid currentColor;transform:rotate(45deg) translateY(-1px);opacity:.5;transition:transform .2s}
.ni:hover .chev{transform:rotate(225deg) translateY(-1px)}
.dd{display:none;position:absolute;top:100%;left:0;background:var(--lava);border:1px solid rgba(146,186,74,.18);border-top:2px solid var(--lime);min-width:210px;z-index:400;box-shadow:0 16px 48px rgba(0,0,0,.7)}
.ni:hover .dd{display:block}
.dd-cat{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:var(--lime);padding:12px 18px 4px;opacity:.65}
.dd a{display:block;padding:9px 18px;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--gray-light);text-decoration:none;border-bottom:1px solid rgba(255,255,255,.03);transition:all .15s}
.dd a:hover{color:var(--lime);background:rgba(146,186,74,.06);padding-left:26px}
.nright{margin-left:auto;display:flex;gap:8px;align-items:center}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 18px;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;cursor:pointer;transition:all .2s;border:none}
.btn-lime{background:var(--lime);color:var(--lava-deep)}.btn-lime:hover{background:var(--lime-bright);transform:translateY(-1px)}
.btn-ghost{background:transparent;color:var(--white);border:1.5px solid rgba(255,255,255,.2)}.btn-ghost:hover{border-color:var(--lime);color:var(--lime)}
.hero{position:relative;height:calc(100vh - 96px);min-height:580px;max-height:900px;overflow:hidden;display:flex;align-items:flex-end}
.hero-img{position:absolute;inset:0;background-size:cover;background-position:center 25%;transform:scale(1.04);animation:hzoom 14s ease-out forwards}
@keyframes hzoom{to{transform:scale(1)}}
.hero-ov{position:absolute;inset:0;background:linear-gradient(to right,rgba(22,25,28,.97) 26%,rgba(22,25,28,.5) 58%,rgba(22,25,28,.05) 100%),linear-gradient(to top,rgba(22,25,28,1) 0%,transparent 42%);z-index:1}
.hero-lupo{position:absolute;bottom:0;right:4%;z-index:5;height:72%;opacity:.11;animation:fup .8s .5s both}
.hero-lupo img{height:100%;width:auto}
.hero-content{position:relative;z-index:10;padding:0 48px 56px;max-width:700px}
.hero-ey{display:inline-flex;align-items:center;gap:8px;font-size:10px;letter-spacing:.28em;text-transform:uppercase;color:var(--lime);margin-bottom:12px;opacity:0;animation:fup .7s .1s forwards}
.ldot{width:7px;height:7px;background:var(--lime);border-radius:50%;animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.35;transform:scale(.65)}}
.hero-title{font-size:clamp(52px,8vw,108px);font-weight:900;letter-spacing:-.02em;line-height:.88;text-transform:uppercase;color:var(--white);margin-bottom:6px;opacity:0;animation:fup .7s .2s forwards}
.hero-title .ac{color:var(--lime)}
.hero-sub{font-size:clamp(11px,1.4vw,15px);letter-spacing:.32em;text-transform:uppercase;color:var(--gray);margin-bottom:10px;opacity:0;animation:fup .7s .25s forwards}
.hero-motto{font-size:clamp(16px,2.2vw,26px);letter-spacing:.18em;text-transform:uppercase;color:rgba(146,186,74,.55);font-weight:900;margin-bottom:28px;opacity:0;animation:fup .7s .3s forwards}
.hero-motto span{color:var(--lime)}
.hero-acts{display:flex;gap:12px;flex-wrap:wrap;opacity:0;animation:fup .7s .4s forwards}
@keyframes fup{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fi{to{opacity:1}}
.hero-ng{position:absolute;bottom:36px;right:48px;z-index:10;background:rgba(28,31,35,.93);border:1px solid rgba(146,186,74,.22);border-left:3px solid var(--lime);padding:16px 22px;min-width:268px;opacity:0;animation:fi .7s .65s forwards}
.ng-l{font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:var(--lime);margin-bottom:8px}
.ng-t{display:flex;align-items:center;gap:8px;margin-bottom:5px}
.ng-n{font-size:15px;font-weight:900;letter-spacing:.05em;text-transform:uppercase}
.ng-vs{font-size:10px;color:var(--gray)}
.ng-m{font-size:11px;color:var(--gray);margin-bottom:12px}
.scroll-h{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);z-index:10;display:flex;flex-direction:column;align-items:center;gap:5px;opacity:.3;animation:bob 2.8s ease infinite}
@keyframes bob{0%,100%{opacity:.3;transform:translateX(-50%) translateY(0)}50%{opacity:.6;transform:translateX(-50%) translateY(5px)}}
.scroll-line{width:1px;height:26px;background:var(--lime)}.scroll-lbl{font-size:8px;letter-spacing:.2em;text-transform:uppercase;color:var(--lime)}
.wolfpack-bar{background:var(--lime);display:flex;align-items:center;justify-content:center;gap:14px;padding:0 40px;height:42px;overflow:hidden}
.wp-t{font-size:11px;font-weight:900;letter-spacing:.3em;text-transform:uppercase;color:var(--lava-deep)}
.wp-s{font-size:14px;font-weight:900;color:rgba(28,31,35,.3)}
.ticker{background:var(--lava-mid);border-bottom:1px solid rgba(146,186,74,.07);overflow:hidden;height:34px;display:flex;align-items:center}
.ticker-lbl{background:var(--lime);color:var(--lava-deep);font-size:9px;font-weight:900;letter-spacing:.22em;text-transform:uppercase;padding:0 16px;height:100%;display:flex;align-items:center;white-space:nowrap;flex-shrink:0}
.ticker-track{display:flex;white-space:nowrap;animation:scroll 34s linear infinite}
@keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.ti{font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--gray-light);padding:0 28px;border-right:1px solid rgba(255,255,255,.06)}
.ti b{color:var(--lime)}
section,.sec{padding:72px 48px}
.ey{font-size:10px;letter-spacing:.26em;text-transform:uppercase;color:var(--lime);margin-bottom:7px;display:block}
.sh{font-size:clamp(26px,3.8vw,46px);font-weight:900;letter-spacing:-.01em;text-transform:uppercase;line-height:1}
.sh .dim{color:var(--gray)}.rule{width:40px;height:2px;background:var(--lime);margin-top:12px}
.news-grid{display:grid;grid-template-columns:1.65fr 1fr 1fr;gap:2px}
.nc{position:relative;overflow:hidden;cursor:pointer;background:var(--lava-mid)}
.nc img{width:100%;height:100%;object-fit:cover;transition:transform .55s;display:block}
.nc:hover img{transform:scale(1.06)}
.nc-main{height:430px}.nc-sm{height:213px}
.no{position:absolute;inset:0;background:linear-gradient(to top,rgba(22,25,28,.96) 0%,rgba(22,25,28,.2) 55%,transparent 100%);transition:background .3s}
.nc:hover .no{background:linear-gradient(to top,rgba(22,25,28,.98) 0%,rgba(22,25,28,.55) 70%,rgba(22,25,28,.1) 100%)}
.ni2{position:absolute;bottom:0;left:0;right:0;padding:18px}
.nc-cat{display:inline-block;font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--lime);background:rgba(146,186,74,.12);padding:3px 8px;margin-bottom:6px}
.nc-h{font-size:clamp(13px,1.7vw,18px);font-weight:900;letter-spacing:.02em;text-transform:uppercase;line-height:1.15;margin-bottom:4px}
.nc-sm .nc-h{font-size:13px}.nc-meta{font-size:10px;color:var(--gray)}
.wp-split{display:grid;grid-template-columns:1fr 1fr;min-height:460px}
.wp-img-wrap{position:relative;overflow:hidden}
.wp-img-wrap img{width:100%;height:100%;object-fit:cover;filter:brightness(.45) saturate(.55);transition:filter .4s}
.wp-img-wrap:hover img{filter:brightness(.6) saturate(.85)}
.wp-img-ov{position:absolute;inset:0;background:linear-gradient(to right,rgba(22,25,28,.5) 0%,rgba(22,25,28,.05) 100%)}
.wp-copy{background:var(--lava-mid);padding:60px 52px;display:flex;flex-direction:column;justify-content:center}
.wp-big{font-size:clamp(58px,7.5vw,106px);font-weight:900;letter-spacing:-.02em;text-transform:uppercase;line-height:.85;color:var(--white);margin-bottom:4px}
.wp-big span{color:var(--lime);display:block}
.wp-sub{font-size:13px;letter-spacing:.28em;text-transform:uppercase;color:var(--gray);margin-bottom:18px}
.wp-desc{font-size:15px;line-height:1.7;color:var(--gray-light);max-width:420px;margin-bottom:26px}
.wp-lupo-tag{display:inline-flex;align-items:center;gap:10px;background:var(--lime-dim);border:1px solid rgba(146,186,74,.2);padding:9px 14px;margin-bottom:22px;font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--lime)}
.wp-lupo-icon{width:28px;height:28px;object-fit:contain}
.match-bg{background:var(--lava-mid);padding:72px 48px}
.match-grid{display:grid;grid-template-columns:1fr 1fr;gap:28px;margin-top:36px}
.mc{background:var(--lava);border:1px solid rgba(255,255,255,.06);padding:24px;position:relative;overflow:hidden;transition:border-color .2s}
.mc:hover{border-color:rgba(146,186,74,.3)}
.mc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--lime);transform:scaleX(0);transition:transform .3s;transform-origin:left}
.mc:hover::before{transform:scaleX(1)}
.mc-comp{font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:var(--lime);margin-bottom:10px}
.mc-date{font-size:11px;color:var(--gray);margin-bottom:14px}
.mc-teams{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.mc-team{text-align:center;flex:1}
.mc-name{font-size:clamp(13px,1.8vw,17px);font-weight:900;letter-spacing:.04em;text-transform:uppercase;line-height:1.1}
.mc-short{font-size:10px;color:var(--gray);margin-top:2px}
.mc-vs{font-size:11px;font-weight:900;color:var(--gray);padding:0 10px;flex-shrink:0}
.mc-score{text-align:center;font-size:clamp(26px,4vw,46px);font-weight:900;margin-bottom:14px}
.mc-score .h{color:var(--white)}.mc-score .s{color:var(--gray)}.mc-score .a{color:var(--gray-light)}
.mc-acts{display:flex;gap:8px;flex-wrap:wrap}
.mca{flex:1;padding:8px;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;text-align:center;text-decoration:none;transition:all .2s;border:1px solid rgba(255,255,255,.1);color:var(--gray-light);display:flex;align-items:center;justify-content:center;gap:5px}
.mca:hover{border-color:var(--lime);color:var(--lime);background:var(--lime-dim)}
.mca.p{background:var(--lime);color:var(--lava-deep);border-color:var(--lime)}.mca.p:hover{background:var(--lime-bright)}
.sched{width:100%;border-collapse:collapse;margin-top:28px}
.sched th{font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:var(--gray);border-bottom:1px solid rgba(255,255,255,.06);padding:10px 12px;text-align:left;font-weight:400}
.sched td{padding:11px 12px;font-size:12px;color:var(--gray-light);border-bottom:1px solid rgba(255,255,255,.04)}
.sched tr:hover td{background:rgba(146,186,74,.03)}
.td-d{color:var(--white)!important;font-weight:700}.td-n{color:var(--white)!important;font-weight:700}
.td-r{font-weight:900;font-size:14px!important}.ww{color:var(--lime)!important}.ll{color:#e05555!important}
.bdg{font-size:9px;letter-spacing:.1em;text-transform:uppercase;background:rgba(146,186,74,.1);color:var(--lime);padding:2px 7px}
.atmo{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;height:230px}
.ac{overflow:hidden;cursor:pointer;position:relative}
.ac img{width:100%;height:100%;object-fit:cover;transition:transform .5s;filter:brightness(.65) saturate(.7)}
.ac:hover img{transform:scale(1.08);filter:brightness(.85) saturate(1)}
.ac-l{position:absolute;bottom:0;left:0;right:0;padding:10px 12px;font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.5);opacity:0;transition:opacity .2s;background:linear-gradient(to top,rgba(22,25,28,.7),transparent)}
.ac:hover .ac-l{opacity:1}
.kader-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:2px;margin-top:36px}
.pc{position:relative;overflow:hidden;cursor:pointer;aspect-ratio:.72}
.pc img{width:100%;height:100%;object-fit:cover;object-position:top center;transition:transform .4s}
.pc:hover img{transform:scale(1.07)}
.pc-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(22,25,28,.95) 0%,transparent 50%);transition:background .3s}
.pc:hover .pc-ov{background:linear-gradient(to top,rgba(146,186,74,.18) 0%,rgba(22,25,28,.7) 50%,rgba(22,25,28,.1) 100%)}
.pc-info{position:absolute;bottom:0;left:0;right:0;padding:11px}
.pc-num{font-size:22px;font-weight:900;color:rgba(146,186,74,.28);line-height:1;margin-bottom:1px}
.pc-name{font-size:12px;font-weight:900;letter-spacing:.06em;text-transform:uppercase}
.pc-pos{font-size:10px;color:var(--gray);margin-top:1px}
.pc-ph{aspect-ratio:.72;background:var(--lava-mid);position:relative;display:flex;align-items:flex-end;overflow:hidden;padding:11px}
.pc-ph::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(45deg,transparent,transparent 8px,rgba(146,186,74,.025) 8px,rgba(146,186,74,.025) 9px)}
.fans-wrap{position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center}
.fans-bg{position:absolute;inset:0;background-size:cover;background-position:center}
.fans-ov{position:absolute;inset:0;background:linear-gradient(135deg,rgba(22,25,28,.97) 0%,rgba(22,25,28,.68) 55%,rgba(22,25,28,.3) 100%)}
.fans-content{position:relative;z-index:2;padding:72px 48px;max-width:580px}
.fdesc{font-size:15px;line-height:1.7;color:var(--gray-light);margin:14px 0 22px;max-width:440px}
.fstats{display:flex;gap:28px;margin-bottom:28px}
.fsn{font-size:clamp(26px,4vw,42px);font-weight:900;color:var(--lime);line-height:1}
.fsl{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--gray);margin-top:2px}
.tcta{background:var(--lime);padding:52px 48px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap}
.tc-ey{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:rgba(28,31,35,.5);margin-bottom:4px}
.tc-t{font-size:clamp(22px,4vw,44px);font-weight:900;letter-spacing:-.01em;text-transform:uppercase;color:var(--lava-deep);line-height:.93}
.tc-acts{display:flex;gap:10px;flex-wrap:wrap;flex-shrink:0}
.btn-dk{background:var(--lava-deep);color:var(--white);padding:12px 26px;font-size:11px;font-weight:900;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;transition:background .2s}
.btn-dk:hover{background:var(--lava-mid)}
.btn-dk-ol{background:transparent;color:var(--lava-deep);padding:12px 26px;font-size:11px;font-weight:900;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;border:2px solid var(--lava-deep);transition:all .2s}
.btn-dk-ol:hover{background:rgba(28,31,35,.08)}
.biz-bg{background:var(--lava-mid);padding:72px 48px}
.biz-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;margin-top:36px}
.bc{background:var(--lava);padding:28px 24px;border:1px solid rgba(255,255,255,.04);transition:border-color .2s,background .2s;cursor:pointer}
.bc:hover{border-color:rgba(146,186,74,.2);background:rgba(146,186,74,.02)}
.bico{width:40px;height:40px;background:var(--lime-dim);display:flex;align-items:center;justify-content:center;margin-bottom:14px}
.bico svg{width:19px;height:19px;fill:none;stroke:var(--lime);stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
.bh{font-size:14px;font-weight:900;letter-spacing:.06em;text-transform:uppercase;margin-bottom:7px}
.bp{font-size:13px;color:var(--gray);line-height:1.65;margin-bottom:14px}
.blnk{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--lime);text-decoration:none;display:inline-flex;align-items:center;gap:5px;transition:gap .2s}
.blnk:hover{gap:9px}
.tabelle-grid{display:grid;grid-template-columns:1fr 1fr;gap:28px;margin-top:36px;align-items:start}
.tabelle-table{width:100%;border-collapse:collapse}
.tabelle-table thead th{font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:var(--gray);border-bottom:1px solid rgba(255,255,255,.06);padding:8px 10px;text-align:left;font-weight:400}
.tabelle-table td{padding:9px 10px;font-size:12px;color:var(--gray-light);border-bottom:1px solid rgba(255,255,255,.03)}
.tabelle-table tr:hover td{background:rgba(146,186,74,.03)}
.tabelle-table .highlight td{color:var(--white);font-weight:700;background:rgba(146,186,74,.07)}
.tabelle-table .pos{color:var(--gray);min-width:22px}
.team-banner{position:relative;overflow:hidden;height:340px}
.team-banner img{width:100%;height:100%;object-fit:cover;object-position:center 25%;filter:brightness(.5) saturate(.7)}
.team-ov{position:absolute;inset:0;background:linear-gradient(to right,rgba(22,25,28,.93) 0%,rgba(22,25,28,.2) 65%);display:flex;align-items:center;padding:52px 48px}
.partner-sec{padding:40px 48px;border-top:1px solid rgba(255,255,255,.05)}
.plbl{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--gray);text-align:center;margin-bottom:20px}
.prow{display:flex;align-items:center;justify-content:center;gap:32px;flex-wrap:wrap}
.pi{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.18);transition:color .2s;cursor:pointer}
.pi:hover{color:rgba(255,255,255,.6)}
footer{background:var(--lava-deep);padding:52px 48px 22px;border-top:2px solid rgba(146,186,74,.12)}
.fg{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:36px;margin-bottom:36px}
.fct{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--lime);margin-bottom:12px;font-weight:700}
.fc a{display:block;font-size:12px;color:var(--gray);text-decoration:none;padding:3px 0;transition:color .15s}
.fc a:hover{color:var(--white)}
