<script>
// Spielerbilder laden – CORS-aware mit Fallback
document.addEventListener('DOMContentLoaded', function() {
  var imgs = document.querySelectorAll('.pc img[data-src]');
  imgs.forEach(function(img) {
    var src = img.getAttribute('data-src');
    var testImg = new Image();
    testImg.crossOrigin = 'anonymous';
    testImg.onload = function() {
      img.src = src;
      img.style.opacity = '1';
      img.style.position = 'absolute';
      img.style.inset = '0';
      img.style.width = '100%';
      img.style.height = '100%';
      img.style.objectFit = 'cover';
      img.style.objectPosition = 'top center';
      var bg = img.closest('.pc').querySelector('.pc-bg');
      if (bg) bg.style.display = 'none';
    };
    testImg.onerror = function() {
      // CORS geblockt – Bild direkt via src setzen (funktioniert ohne crossOrigin-Check)
      img.removeAttribute('crossOrigin');
      img.src = src;
      img.style.opacity = '1';
      img.style.position = 'absolute';
      img.style.inset = '0';
      img.style.width = '100%';
      img.style.height = '100%';
      img.style.objectFit = 'cover';
      img.style.objectPosition = 'top center';
    };
    testImg.src = src;
  });
});
</script>

